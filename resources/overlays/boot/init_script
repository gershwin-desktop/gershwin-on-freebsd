#!/rescue/sh
# /boot/init_script — Gershwin live ISO boot pivot.
#
# Runs as a child of /sbin/init via the init_script kenv. Sets up an
# in-kernel unionfs overlay (read-only uzip lower + tmpfs writable upper)
# at /sysroot, then sets init_chroot=/sysroot so init chroots there and
# continues a normal multi-user boot. cd9660 stays the kernel's real
# root, hidden from the chroot.
#
# This replaces the old piecemeal nullfs-per-directory overlay, which
# had to neuter /etc/rc.d/{cleanvar,var,cleartmp,tmp,hostname} to keep
# the normal rc boot from fighting the hand-built mounts. With a single
# unionfs root the real rc.d scripts run untouched.

set -eu
PATH=/rescue
export PATH

# End users shouldn't see the pivot internals. If something fails,
# set -e bubbles up and init drops to single-user for investigation.
exec 1>/dev/null 2>&1

# Modules used below (also requested in loader.conf; load defensively).
kldload geom_uzip 2>/dev/null || true
kldload unionfs 2>/dev/null || true

# Vnode-mount the compressed rootfs from the cd9660. geom_uzip auto-tastes
# /dev/md0 and produces /dev/md0.uzip.
mdconfig -a -t vnode -o readonly -f /boot/rootfs.uzip -u 0

# Wait for the uzip taste to complete.
i=0
while [ ! -e /dev/md0.uzip ]; do
	sleep 1
	i=$((i + 1))
	[ "$i" -gt 30 ] && halt -p
done

# Read-only lower at /sysroot, tmpfs writable upper, in-kernel unionfs
# merges them — /sysroot becomes the writable merged root.
mount -t ufs -o ro /dev/md0.uzip /sysroot
mount -t tmpfs tmpfs /upper
mount -t unionfs /upper /sysroot
mount -t devfs devfs /sysroot/dev

# root_rw_mount="NO" is live-only: from inside the chroot, mount(8)
# inspects the kernel mount table and sees the kernel's real root
# (cd9660), so /etc/rc.d/root's `mount -uw /` would dispatch against the
# optical device and fail. The unionfs root is already writable, so the
# remount isn't needed. Write this into the tmpfs upper so it applies to
# the live system only — it never lands in the uzip, so an installed
# system (which DOES need the rw remount) is unaffected.
echo 'root_rw_mount="NO"' >> /sysroot/etc/rc.conf.local

# Hand off: init reads init_chroot after this script exits, chroots into
# /sysroot, and continues a normal multi-user boot.
kenv init_chroot=/sysroot
kenv -u init_script 2>/dev/null || true
kenv -u init_shell 2>/dev/null || true

exit 0
